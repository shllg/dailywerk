# Ruby / Rails
/.bundle
/vendor/bundle
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep
/config/*.key

# Environment files
/.env*
!/.env.tpl
!/.env.example

# Frontend
/frontend/node_modules
/frontend/dist

# OS
.DS_Store

# obsidian
docs/.obsidian

# Ignore key files for decrypting credentials and more.
/config/*.key
/config/credentials/*.key

# Per-environment credentials — only development.yml.enc is tracked
/config/credentials/*.yml.enc
!/config/credentials/development.yml.enc

