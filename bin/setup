#!/usr/bin/env bash
set -e

echo "== Installing Ruby dependencies =="
bundle check || bundle install

if ! command -v overmind >/dev/null 2>&1; then
  echo ""
  echo "== Installing overmind (process manager) =="
  gem install overmind --no-document
fi

echo ""
echo "== Installing frontend dependencies =="
cd frontend && pnpm install && cd ..

echo ""
echo "== Starting Docker services =="
docker compose up -d --wait

echo ""
echo "== Creating S3 bucket =="
docker compose --profile setup run --rm rustfs-setup

echo ""
echo "== Preparing database =="
bin/rails db:prepare

echo ""
echo "== Removing old logs and tempfiles =="
bin/rails log:clear tmp:clear

echo ""
echo "Setup complete! Run bin/dev to start the application."
