#!/usr/bin/env bash
# Usage: bin/credentials-edit <environment>
# Opens Rails credentials editor with the master key from 1Password.
set -euo pipefail

env="${1:?Usage: bin/credentials-edit <environment>}"

# Map environment to 1Password secret path
case "$env" in
  production)
    op_path="op://DailyWerkServer/prod-rails/master-key"
    ;;
  staging)
    op_path="op://DailyWerkServer/staging-rails/master-key"
    ;;
  development)
    op_path="op://DailyWerk/dailywerk-dev-env/rails-master-key"
    ;;
  *)
    echo "Unknown environment: $env" >&2
    echo "Supported: development, staging, production" >&2
    exit 1
    ;;
esac

key=$(op read "$op_path")
RAILS_MASTER_KEY="$key" bin/rails credentials:edit --environment "$env"
