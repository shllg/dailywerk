#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

if [ -x ./bin/load-env ]; then
  eval "$(./bin/load-env)"
fi

if [ "$#" -gt 0 ]; then
  test_targets=("$@")
else
  test_targets=(
    test/controllers
    test/integration
    test/jobs
    test/mailers
    test/models
    test/services
    test/tools
  )
fi

bin/rails db:test:prepare
bin/rails test "${test_targets[@]}"
