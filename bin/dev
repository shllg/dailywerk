#!/usr/bin/env bash
set -e

# Load worktree overrides if present (ports, DB, Valkey, etc.)
if [ -f .env.worktree ]; then
  set -a
  source .env.worktree
  set +a
fi

# Defaults
export PORT="${PORT:-3000}"
export VITE_PORT="${VITE_PORT:-5173}"
export VITE_API_PORT="${VITE_API_PORT:-$PORT}"

# Start Docker services unless told to skip (worktrees share main's stack)
if [ "${SKIP_DOCKER:-0}" != "1" ]; then
  echo "Starting Docker services..."
  docker compose up -d --wait

  echo "Preparing database..."
  bin/rails db:prepare
fi

echo "Starting all processes..."
if command -v overmind >/dev/null 2>&1; then
  overmind start -f Procfile.dev
elif command -v foreman >/dev/null 2>&1; then
  foreman start -f Procfile.dev
else
  echo "Error: Install overmind or foreman to run all processes."
  echo "  gem install foreman"
  exit 1
fi
